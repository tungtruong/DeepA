OPENAI_API_KEY=your_openai_api_key
# Optional: dùng Anthropic thay OpenAI
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: override model (ví dụ: openai:gpt-5, openai:gpt-4.1)
# DEEPAGENT_MODEL=openai:gpt-4.1-mini

# Optional: bật tìm kiếm internet bằng Tavily
TAVILY_API_KEY=your_tavily_api_key

# Bắt buộc nếu chạy bot Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: chỉ cho phép các Telegram user ID này dùng bot (phân tách bằng dấu phẩy)
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321